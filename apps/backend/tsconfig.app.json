{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "./dist",
    "types": ["node"],
    "paths": {
      "@common/*": ["../../../apps/backend/src/common/*"],
      "@modules/*": ["../../../apps/backend/src/modules/*"],
      "@integrations/*": ["../../../apps/backend/src/integrations/*"]
    }
  },
  "include": [
    "src/**/*",
    "../../src/modules/reports/**/*.ts",
    "../../src/modules/reports/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "../../src/modules/reports/**/*.spec.ts"]
}
